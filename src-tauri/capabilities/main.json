{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "main-window",
  "description": "Permissions for the main app window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.resume-editor" },
        { "path": "$HOME/.resume-editor/**" }
      ]
    },
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "notification:default"
  ]
}
